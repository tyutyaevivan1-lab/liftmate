BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
# Необязательно: адрес задеплоенного Web App, по умолчанию уже указан в config.py
WEBAPP_URL=https://liftmate-webapp.vercel.app
# На Railway создаётся автоматически при подключении плагина PostgreSQL к проекту.
# Для локальной разработки укажи свою строку подключения, например:
DATABASE_URL=postgresql://postgres:password@localhost:5432/liftmate
# Один Telegraph-аккаунт для бота (создаётся один раз через telegraph.aio.Telegraph().
# create_account(), см. program.py) — переиспользуется для всех страниц с программами
# тренировок, чтобы не плодить новый аккаунт на каждый вызов. Необязательно: без него
# бот просто откатывается на текстовую отправку по дням (см. program.publish_program).
TELEGRAPH_ACCESS_TOKEN=your_telegraph_access_token_here
